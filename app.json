{
  "expo": {
    "name": "MediScan AI",
    "slug": "mediscanai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font", 
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MediScan AI to access your camera to scan medicines."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MediScan AI to access your photos to select medicine images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
